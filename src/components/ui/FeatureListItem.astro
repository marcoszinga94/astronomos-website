---
export interface Props {
  icon: string;
  title: string;
  text: string;
}

const { icon, title, text } = Astro.props;
---

<div class="flex items-center gap-3 py-2.5 px-4 bg-bg3 border border-white/5 rounded-lg">
  <span class="text-2xl">{icon}</span>
  <div class="flex-1">
    <div class="text-15 font-medium text-t1">{title}</div>
    <div class="text-13 text-t2">{text}</div>
  </div>
</div>
