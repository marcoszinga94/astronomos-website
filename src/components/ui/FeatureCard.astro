---
export interface Props {
  icon?: string;
  title: string;
  text: string;
  iconStyle?: "emoji" | "dot";
}

const { icon = "", title, text, iconStyle = "emoji" } = Astro.props;
---

<div class="flex gap-3.5 items-start p-5 bg-bg3 border border-white/5 rounded-xl">
  {iconStyle === "emoji" && <span class="text-2xl shrink-0 mt-0.5">{icon}</span>}
  {iconStyle === "dot" && <span class="w-1.5 h-1.5 rounded-full bg-a1 shrink-0 mt-1.5 shadow-[0_0_6px_var(--color-a1)]"></span>}
  <div>
    <div class="font-mono text-2xs tracking-wider uppercase text-t2 mb-1">{title}</div>
    <p class="text-15 text-t2 leading-relaxed">{text}</p>
  </div>
</div>
