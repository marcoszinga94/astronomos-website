---
export interface Props {
  icon: string;
  title: string;
  text: string;
}

const { icon, title, text } = Astro.props;
---

<div class="bg-bg3 border border-white/5 rounded-xl p-[22px] flex flex-col gap-2.5 transition-all hover:border-a1/25 hover:-translate-y-0.5">
  <span class="text-2xl">{icon}</span>
  <h3 class="text-[13px] font-semibold text-t1">{title}</h3>
  <p class="text-[12px] text-t2 leading-relaxed font-light">{text}</p>
</div>
