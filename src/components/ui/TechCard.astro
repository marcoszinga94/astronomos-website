---
export interface Props {
  logo: string;
  logoBg: string;
  role: string;
  name: string;
  desc: string;
  bridgeLabel: string;
  bridgeText: string;
}

const { logo, logoBg, role, name, desc, bridgeLabel, bridgeText } = Astro.props;
---

<div class="bg-bg3 border border-white/5 rounded-xl p-6 flex flex-col gap-3 transition-all hover:border-a1/30 hover:-translate-y-0.5 relative overflow-hidden">
  <div class="flex items-start gap-3">
    <div class="w-11 h-11 rounded-xl flex items-center justify-center font-mono font-bold text-[13px] text-white shrink-0" style={`background: ${logoBg}`}>
      {logo}
    </div>
    <div>
      <div class="font-mono text-[9px] tracking-wider uppercase text-a1 mb-1">{role}</div>
      <div class="text-[15px] font-semibold text-t1">{name}</div>
    </div>
  </div>
  <p class="text-[12px] text-t2 leading-relaxed font-light">{desc}</p>
  <div class="flex items-center gap-2 mt-1.5 py-2 px-2.5 bg-a1/5 border-l-2 border-a1 rounded-r-md">
    <span class="font-mono text-[9px] tracking-wider uppercase text-a1/70 shrink-0">{bridgeLabel}</span>
    <span class="text-[11px] text-t2">{bridgeText}</span>
  </div>
</div>
