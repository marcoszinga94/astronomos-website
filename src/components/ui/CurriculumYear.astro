---
export interface Props {
  year: string;
  title: string;
  subjects: { name: string; highlight?: boolean }[];
}

const { year, title, subjects } = Astro.props;
---

<div class="bg-bg2 border border-white/5 rounded-xl overflow-hidden transition-all hover:border-a1/25 hover:-translate-y-0.5">
  <div class="px-5 py-3.5 flex items-center gap-2.5 border-b border-white/5 bg-bg3">
    <div class="font-mono text-[10px] tracking-wider uppercase text-a1">{year}</div>
    <div class="text-[14px] font-semibold text-t1">{title}</div>
  </div>
  <div class="px-5 py-3.5 flex flex-col gap-[7px]">
    {subjects.map((subj) => (
      <div class="text-[12px] text-t2 flex items-start gap-2 leading-relaxed">
        <span class="text-a1/50 shrink-0 font-mono text-[11px] mt-0.5">→</span>
        <span class={subj.highlight ? "text-t1 font-medium" : ""}>{subj.name}</span>
      </div>
    ))}
  </div>
</div>
