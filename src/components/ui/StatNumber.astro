---
export interface Props {
  number: string;
  suffix?: string;
  suffixClass?: string;
  label: string;
}

const { number, suffix = "", suffixClass = "text-base text-a1 align-super", label } = Astro.props;
---

<div class="text-center py-4 px-[22px] bg-white/4 border border-white/5 rounded-xl min-w-[110px]">
  <div class="font-mono text-[30px] font-medium text-t1 leading-none flex items-baseline justify-center gap-0.5">
    {number}{suffix && <span class={suffixClass}>{suffix}</span>}
  </div>
  <div class="text-[12px] text-t2 tracking-wider uppercase mt-1">{label}</div>
</div>
