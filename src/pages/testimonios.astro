---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader";
import Section from "../components/ui/Section.astro";
import SkillCard from "../components/ui/SkillCard.astro";
import TestimonialCard from "../components/TestimonialCard";
import { testimonials, competencias, salidasLaborales } from "../data/content";
---

<BaseLayout title="Testimonios — Voces del proyecto">
  <Section>
    <SectionHeader eyebrow="Voces del proyecto" title="Lo que dicen" highlight="los protagonistas" subtitle="Tres perspectivas que muestran el impacto real del proyecto: quienes aprendieron jugando, quienes programaron y quienes acompañaron el proceso." />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {testimonials.map((t) => (
        <TestimonialCard key={t.name} testimonial={t} />
      ))}
    </div>
  </Section>

  <Section bg="bg-bg2">
    <div class="grid lg:grid-cols-2 gap-14 items-center">
      <div>
        <SectionHeader eyebrow="Perfil profesional egresado" title="Del aula al" highlight="mundo real" subtitle="No solo aprender a programar. Desarrollar las competencias que las empresas tecnológicas buscan en sus equipos." />

        <div class="grid grid-cols-2 gap-3">
          {competencias.map((c) => (
            <SkillCard key={c.title} icon={c.icon} title={c.title} text={c.text} />
          ))}
        </div>
      </div>

      <div class="flex flex-col gap-6">
        <div class="bg-bg3 border border-white/5 rounded-[20px] p-8 relative">
          <span class="text-[72px] leading-[0.8] text-a1/12 font-serif absolute top-4 left-5">&ldquo;</span>
          <p class="text-[clamp(16px,2vw,20px)] text-t1 font-light leading-relaxed italic relative pt-6">
            Los estudiantes no aprenden a programar para después trabajar. Trabajan desde el primer día para aprender a programar mejor.
          </p>
          <div class="mt-4 font-mono text-[10px] text-t3 tracking-wider uppercase">
            — Filosofía · Tecnicatura en Programación Full Stack · El Nacional · UPC
          </div>
        </div>
        <div class="bg-bg3 border border-white/5 rounded-xl p-6 flex flex-col gap-3">
          <div class="font-mono text-[9px] tracking-wider uppercase text-a1">Salida laboral</div>
          <div class="flex flex-col gap-2">
            {salidasLaborales.map((s) => (
              <div class="text-[13px] text-t2 flex gap-2 items-center"><span class="text-green">✓</span> {s}</div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
