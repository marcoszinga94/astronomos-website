---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader";
import Section from "../components/ui/Section.astro";
import Reveal from "../components/Reveal.astro";
import Button from "../components/ui/Button.astro";
import SectionEyebrow from "../components/ui/SectionEyebrow.astro";
import BannerCard from "../components/ui/BannerCard.astro";
import StatNumber from "../components/ui/StatNumber.astro";
import CurriculumYear from "../components/ui/CurriculumYear.astro";
import CareerCard from "../components/ui/CareerCard.astro";
import { curriculum, careerCards, carreraStats } from "../data/content";
---

<BaseLayout
  title="Inicio"
  description="Escuela Superior El Nacional — La Carlota, Córdoba. Nivel secundario y tecnicaturas superiores. Próximo convenio UPC."
>
  <Reveal>
    <section
      class="min-h-screen flex items-center pt-[calc(60px+60px)] pb-20 relative overflow-hidden before:content-[''] before:absolute before:inset-0 before:bg-[linear-gradient(rgba(79,127,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(79,127,255,0.03)_1px,transparent_1px)] before:bg-[size:72px_72px] before:[mask-image:radial-gradient(ellipse_80%_80%_at_50%_50%,black_15%,transparent_100%)] before:pointer-events-none after:content-[''] after:absolute after:top-0 after:right-0 after:w-[500px] after:h-[400px] after:bg-[radial-gradient(ellipse,rgba(79,127,255,0.06),transparent_70%)] after:pointer-events-none after:blur-30"
    >
      <div class="max-w-[1120px] mx-auto px-10 max-md:px-5 w-full">
        <div class="max-w-180">
          <div
            class="inline-flex items-center gap-2 font-mono text-xs tracking-widest uppercase text-a1 bg-a1/7 border border-a1/20 rounded-full px-4 py-1.5 mb-6"
          >
            <span
              class="w-1.5 h-1.5 rounded-full bg-green shadow-[0_0_6px_var(--color-green)] animate-[pulse-dot_2s_ease-in-out_infinite]"
            ></span>
            La Carlota, Córdoba · Argentina
          </div>

          <h1
            class="text-[clamp(34px,5vw,62px)] font-extrabold leading-[1.06] tracking-tight"
          >
            <span class="block text-t1">Escuela Superior</span>
            <span
              class="block bg-gradient-to-r from-a1 via-a3 to-a2 bg-clip-text text-transparent drop-shadow-[0_0_32px_rgba(79,127,255,0.3)]"
              >El Nacional</span
            >
          </h1>

          <p
            class="text-[clamp(14px,1.5vw,18px)] text-t2 font-light leading-relaxed mt-6 max-w-160"
          >
            Institución de nivel secundario y superior comprometida con la
            <strong class="text-t1 font-medium"> formación integral</strong> de sus
            estudiantes. Tecnicaturas superiores con
            <strong class="text-t1 font-medium"> próximo convenio UPC</strong>,
            combinando rigor académico con práctica profesional desde el primer
            día.
          </p>

          <div class="flex gap-3 flex-wrap mt-7">
            <Button href="/inscripcion" variant="primary"> Inscribirme </Button>
            <Button href="/proyecto" variant="secondary">
              Conocer el proyecto →
            </Button>
          </div>

          <div
            class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-10 max-w-[680px]"
          >
            <div
              class="bg-bg2 border border-white/5 rounded-xl p-5 text-center flex flex-col gap-1 transition-all hover:border-a1/20 hover:-translate-y-0.5"
            >
              <div class="text-2xl mb-0.5">🏫</div>
              <div class="font-mono text-2xl font-medium text-t1">2</div>
              <div class="text-2xs text-t2 tracking-wider uppercase">
                Niveles educativos
              </div>
            </div>
            <div
              class="bg-bg2 border border-white/5 rounded-xl p-5 text-center flex flex-col gap-1 transition-all hover:border-a1/20 hover:-translate-y-0.5"
            >
              <div class="text-2xl mb-0.5">🎓</div>
              <div class="font-mono text-2xl font-medium text-t1">2+</div>
              <div class="text-2xs text-t2 tracking-wider uppercase">
                Tecnicaturas
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </Reveal>

  <Reveal>
    <Section bg="bg-bg2">
      <SectionHeader
        eyebrow="Niveles educativos"
        title="Formación"
        highlight="integral"
        subtitle="Dos niveles articulados que acompañan al estudiante desde la educación obligatoria hasta la formación profesional con salida laboral inmediata."
      />

      <div class="grid md:grid-cols-2 gap-5">
        <div
          class="bg-bg3 border border-white/5 rounded-xl p-7 flex flex-col gap-3.5 transition-all hover:border-a1/25 hover:-translate-y-0.5 relative overflow-hidden before:content-[''] before:absolute before:top-0 before:left-0 before:right-0 before:h-0.5 before:bg-gradient-to-r before:from-a1 before:to-a3 before:opacity-70"
        >
          <div class="flex items-center gap-3">
            <div
              class="w-12 h-12 rounded-xl bg-a1/10 border border-a1/20 flex items-center justify-center text-2xl"
            >
              🏫
            </div>
            <div>
              <h3 class="text-15 font-bold text-t1">Nivel Secundario</h3>
              <div
                class="font-mono text-2xs tracking-wider uppercase text-a1/80 mt-0.5"
              >
                Educación obligatoria
              </div>
            </div>
          </div>
          <p class="text-15 text-t2 leading-relaxed">
            Formación general con orientación en ciencias y humanidades.
            Preparación para el ingreso al nivel superior y para el mundo
            laboral. Bachillerato completo con materias optativas que acercan al
            alumno al pensamiento científico y tecnológico.
          </p>
        </div>
        <div
          class="bg-bg3 border border-white/5 rounded-xl p-7 flex flex-col gap-3.5 transition-all hover:border-a1/25 hover:-translate-y-0.5 relative overflow-hidden before:content-[''] before:absolute before:top-0 before:left-0 before:right-0 before:h-0.5 before:bg-gradient-to-r before:from-a2 before:to-a3 before:opacity-70"
        >
          <div class="flex items-center gap-3">
            <div
              class="w-12 h-12 rounded-xl bg-a2/10 border border-a2/20 flex items-center justify-center text-2xl"
            >
              🎓
            </div>
            <div>
              <h3 class="text-15 font-bold text-t1">Nivel Superior</h3>
              <div
                class="font-mono text-2xs tracking-wider uppercase text-a2/80 mt-0.5"
              >
                Tecnicaturas superiores
              </div>
            </div>
          </div>
          <p class="text-15 text-t2 leading-relaxed">
            Tecnicaturas superiores con títulos oficiales de validez nacional,
            formación práctica desde el primer año y salida laboral inmediata en
            áreas de alta demanda.
          </p>
          <div class="grid grid-cols-3 gap-2">
            <div
              class="flex items-center gap-1.5 py-1.5 px-2.5 bg-bg2 rounded-md border border-white/5 text-sm"
            >
              <span
                class="w-1.5 h-1.5 rounded-full bg-a3 shrink-0 shadow-[0_0_5px_var(--color-a3)]"
              ></span>
              <span class="text-13 font-medium text-t1">Programación</span>
            </div>
            <div
              class="flex items-center gap-1.5 py-1.5 px-2.5 bg-bg2 rounded-md border border-white/5 text-sm"
            >
              <span
                class="w-1.5 h-1.5 rounded-full bg-green shrink-0 shadow-[0_0_5px_var(--color-green)]"
              ></span>
              <span class="text-13 font-medium text-t1">Administración</span>
            </div>
            <div
              class="flex items-center gap-1.5 py-1.5 px-2.5 bg-bg2 rounded-md border border-white/5 text-sm"
            >
              <span
                class="w-1.5 h-1.5 rounded-full bg-orange shrink-0 shadow-[0_0_5px_var(--color-orange)]"
              ></span>
              <span class="text-13 font-medium text-t1">Otras</span>
            </div>
          </div>
        </div>
      </div>

      <div class="h-12"></div>

      <div
        class="relative bg-linear-to-br from-bg3 to-bg2 border border-a1/30 rounded-xl p-6 flex items-center gap-5 transition-all hover:border-a1/50 hover:shadow-[0_0_24px_-4px_#4f7fff20]"
      >
        <div
          class="w-14 h-14 rounded-xl bg-linear-to-br from-a1 to-a2 flex items-center justify-center font-extrabold text-base text-white shrink-0 shadow-[0_0_16px_-2px_#4f7fff40]"
        >
          UPC
        </div>
        <div>
          <div class="text-base font-bold text-t1 mb-1">
            Universidad Provincial de Córdoba — UPC
          </div>
          <p class="text-sm text-t2 leading-relaxed">
            El Nacional formará parte de la red de instituciones asociadas a la
            UPC, garantizando títulos universitarios oficiales de nivel superior
            con reconocimiento nacional.
          </p>
        </div>
      </div>
    </Section>
  </Reveal>

  <Reveal>
    <Section>
      <SectionEyebrow text="Tecnicatura destacada" />
      <div class="h-6"></div>

      <BannerCard>
        <div class="grid lg:grid-cols-[1fr_auto] gap-8 items-center">
          <div>
            <div
              class="font-mono text-2xs tracking-wider uppercase text-a1/75 mb-2"
            >
              Título oficial · Escuela Superior El Nacional
            </div>
            <h3
              class="text-[clamp(18px,2.5vw,24px)] font-bold text-t1 tracking-tight leading-tight mb-3"
            >
              Técnico Superior en Desarrollo de Software
            </h3>
            <p class="text-15 text-t2 leading-relaxed mb-4 max-w-[520px]">
              Formate como desarrollador de software profesional con un plan de
              estudios actualizado, docentes especializados y prácticas reales
              desde el primer año. La carrera que el mercado está buscando.
            </p>
            <div class="flex flex-wrap gap-2">
              <span
                class="inline-flex items-center gap-1.5 text-sm text-t2 px-3.5 py-1.5 bg-bg3 border border-white/5 rounded-full"
              >
                <span class="text-sm">📍</span>La Carlota, Córdoba
              </span>
              <span
                class="inline-flex items-center gap-1.5 text-sm text-t2 px-3.5 py-1.5 bg-bg3 border border-white/5 rounded-full"
              >
                <span class="text-sm">🎓</span>Título terciario
              </span>
              <span
                class="inline-flex items-center gap-1.5 text-sm text-t2 px-3.5 py-1.5 bg-bg3 border border-white/5 rounded-full"
              >
                <span class="text-sm">💼</span>Práctica desde 1° año
              </span>
              <span
                class="inline-flex items-center gap-1.5 text-sm text-t2 px-3.5 py-1.5 bg-bg3 border border-white/5 rounded-full"
              >
                <span class="text-sm">🏛️</span>Próximo convenio UPC
              </span>
            </div>
          </div>
          <div class="flex flex-col gap-2 shrink-0 min-w-25 text-center">
            {
              carreraStats.map((s) => (
                <StatNumber
                  number={s.number}
                  suffix={s.suffix}
                  suffixClass={s.suffixClass}
                  label={s.label}
                />
              ))
            }
          </div>
        </div>
      </BannerCard>
    </Section>
  </Reveal>

  <Reveal>
    <Section bg="bg-bg2">
      <SectionEyebrow text="Plan de estudios" />
      <h2
        class="text-[clamp(24px,3.5vw,40px)] font-bold tracking-tight leading-tight text-t1 mb-3.5"
      >
        Tres años hacia tu
        <span
          class="bg-gradient-to-r from-a1 to-a2 bg-clip-text text-transparent"
        >
          futuro profesional</span
        >
      </h2>
      <p
        class="text-[clamp(14px,1.4vw,16px)] text-t2 leading-relaxed max-w-[600px] mb-10"
      >
        Un recorrido progresivo desde los fundamentos de la programación hasta
        la especialización profesional, con materias actualizadas y proyectos
        reales cada año.
      </p>
      <div class="grid lg:grid-cols-3 gap-3.5">
        {
          curriculum.map((year) => (
            <CurriculumYear
              key={year.year}
              year={year.year}
              title={year.title}
              subjects={year.subjects}
            />
          ))
        }
      </div>
    </Section>
  </Reveal>

  <Reveal>
    <Section>
      <SectionEyebrow text="Áreas de formación" />
      <h2
        class="text-[clamp(24px,3.5vw,40px)] font-bold tracking-tight leading-tight text-t1 mb-3.5"
      >
        Competencias que el
        <span
          class="bg-linear-to-r from-a1 to-a2 bg-clip-text text-transparent"
        >
          mercado busca</span
        >
      </h2>
      <p
        class="text-[clamp(14px,1.4vw,16px)] text-t2 leading-relaxed max-w-[600px] mb-10"
      >
        Desde programación hasta videojuegos, pasando por bases de datos e
        inteligencia artificial. Un perfil completo para destacar en la
        industria tech.
      </p>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
        {
          careerCards.map((card) => (
            <CareerCard
              key={card.title}
              icon={card.icon}
              title={card.title}
              desc={card.desc}
              tags={card.tags}
              color={card.color}
            />
          ))
        }
      </div>
    </Section>
  </Reveal>

  <Reveal>
    <Section bg="bg-bg2">
      <div class="flex flex-col items-center text-center">
        <div
          class="w-16 h-16 rounded-2xl bg-gradient-to-br from-a1 to-a2 flex items-center justify-center text-3xl shadow-[0_0_32px_rgba(79,127,255,0.2)] mb-6"
        >
          🎓
        </div>
        <h2
          class="text-[clamp(24px,4vw,44px)] font-extrabold tracking-tight leading-[1.1] text-t1 mb-3"
        >
          ¿Listo para empezar?
        </h2>
        <p
          class="text-[clamp(14px,1.4vw,16px)] text-t2 leading-relaxed max-w-[520px] mb-8"
        >
          Convertite en Técnico Superior en Desarrollo de Software. Clases
          presenciales en La Carlota, práctica profesional desde el primer año y
          título oficial.
        </p>
        <div class="flex gap-3 flex-wrap justify-center">
          <Button href="/inscripcion" variant="primary-gradient"
            >Quiero inscribirme →</Button
          >
          <Button href="/proyecto" variant="secondary"
            >Ver proyecto educativo</Button
          >
        </div>
      </div>
    </Section>
  </Reveal>
</BaseLayout>
