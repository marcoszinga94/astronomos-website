---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader";
import Section from "../components/ui/Section.astro";
import TeamCard from "../components/TeamCard";
import Reveal from "../components/Reveal.astro";
import { games } from "../data/games";
---

<BaseLayout title="Estudiantes — Los desarrolladores">
  <Section>
    <SectionHeader as="h1"
      eyebrow="Los desarrolladores"
      title="Los"
      highlight="estudiantes"
      subtitle="Ocho estudiantes de la Tecnicatura en Programación Full Stack. Cada uno diseñó, programó y presentó su videojuego educativo de forma independiente."
    />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        games.map((game, i) => (
          <Reveal>
            <div id={game.slug} key={game.slug} class="card-target">
              <TeamCard game={game} index={i} />
            </div>
          </Reveal>
        ))
      }
    </div>
  </Section>
</BaseLayout>

<style>
  @keyframes glow-pulse {
    0%, 100% {
      box-shadow:
        0 0 0 2px var(--color-a1),
        0 0 30px rgba(79, 127, 255, 0.25),
        0 0 80px rgba(79, 127, 255, 0.12);
    }
    50% {
      box-shadow:
        0 0 0 2px var(--color-a1),
        0 0 50px rgba(79, 127, 255, 0.45),
        0 0 120px rgba(79, 127, 255, 0.2);
    }
  }

  .card-target {
    scroll-margin-top: 35vh;
    border-radius: 20px;
  }
  .card-target:target {
    animation: glow-pulse 2s ease-in-out infinite;
  }
</style>
