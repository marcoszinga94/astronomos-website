---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader";
import Section from "../components/ui/Section.astro";
import Button from "../components/ui/Button.astro";
import Divider from "../components/ui/Divider.astro";
import SectionEyebrow from "../components/ui/SectionEyebrow.astro";
import FeatureCard from "../components/ui/FeatureCard.astro";
import BannerCard from "../components/ui/BannerCard.astro";
import Tag from "../components/ui/Tag.astro";
import { estaciones, timeline } from "../data/proyecto";
---

<BaseLayout title="El Proyecto — Astrónomos por un día">
  <Section>
    <SectionHeader eyebrow="El proyecto educativo · Expo Carrera 2026" title="Un día como" highlight="Astrónomos" subtitle="Una experiencia educativa completa donde niños de primer grado se convierten en astrónomos por un día, guiados por estudiantes secundarios y universitarios a través de cinco estaciones temáticas." />

    <BannerCard bg="bg-gradient-to-br from-a1/6 to-a3/3" border="border-a1/15">
      <p class="text-[clamp(14px,1.7vw,17px)] text-t2 leading-relaxed font-light">
        <strong class="text-t1 font-medium">El proyecto "Astrónomos por un día"</strong> nació de una pregunta simple: ¿qué pasaría si los niños de primer grado pudieran vivir la astronomía en lugar de solo escuchar sobre ella? La respuesta fue una jornada educativa diseñada por estudiantes de secundaria y de la tecnicatura, donde <em class="text-a1/90 not-italic font-medium">niños de 6 y 7 años</em> recorrieron cinco estaciones temáticas, cada una guiada por un estudiante mayor que los acompañó, explicó, jugó y aprendió junto a ellos.
      </p>
      <p class="text-[clamp(14px,1.7vw,17px)] text-t2 leading-relaxed font-light mt-4">
        Durante la jornada, los niños <strong class="text-t1 font-medium">no fueron espectadores sino protagonistas</strong>: observaron el cielo, manipularon instrumentos, conectaron estrellas, descubrieron las fases de la luna y, en la estación final, jugaron videojuegos educativos programados especialmente para ellos por estudiantes de la carrera de Desarrollo de Software.
      </p>
    </BannerCard>

    <div class="grid lg:grid-cols-2 gap-14 items-start">
      <div class="flex flex-col gap-6">
        <FeatureCard icon="🎯" title="Objetivo del proyecto" text="Acercar la astronomía de manera lúdica, participativa y significativa, fortaleciendo la curiosidad científica, el trabajo colaborativo y la articulación entre niveles educativos: primario, secundario y superior." />
        <FeatureCard icon="👶" title="Beneficiarios directos" text="Niños y niñas de primer grado. Aprendizaje por descubrimiento guiado en un entorno seguro, lúdico y diseñado específicamente para su edad y nivel cognitivo." />
        <FeatureCard icon="🤝" title="Metodología: aprendizaje entre pares" text="Estudiantes de nivel secundario y universitario guiaron a los más pequeños. Al enseñar, también aprendieron: comunicación, paciencia, liderazgo y responsabilidad pedagógica." />
        <FeatureCard icon="💡" title="Articulación curricular" text="Integración de contenidos de Ciencias Naturales (astronomía de primer grado), Programación II y Práctica Profesionalizante I de la tecnicatura. Tres materias, un proyecto real." />
      </div>

      <div>
        <div class="font-mono text-[9px] tracking-wider uppercase text-a1 mb-4">Las 5 estaciones temáticas</div>
        <div class="flex flex-col gap-3.5">
          {estaciones.map((est) => (
            <div class={`bg-bg3 border border-white/5 rounded-xl p-5 grid grid-cols-[56px_1fr] gap-4 items-start transition-all hover:border-a1/20 hover:translate-x-1 ${est.featured ? 'border-a1/25 bg-a1/4' : ''}`}>
              <div class="flex flex-col items-center gap-1">
                <span class="text-[26px] leading-none">{est.icono}</span>
                <span class="font-mono text-[8px] tracking-wider text-t3">{est.num}</span>
              </div>
              <div>
                <div class="font-mono text-[9px] tracking-wider uppercase text-t3 mb-0.5">Estación {est.num}</div>
                <h3 class="text-[15px] font-semibold text-t1 mb-1">{est.titulo}</h3>
                <p class="text-[12px] text-t2 leading-relaxed">{est.texto}</p>
                {est.badge && (
                  <Tag variant="a1">{est.badge}</Tag>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <Divider />

    <SectionEyebrow text="Proceso de desarrollo profesional" />
    <h2 class="text-[clamp(24px,3.5vw,40px)] font-bold tracking-tight leading-tight text-t1 mb-3.5">
      ¿Cómo <span class="bg-gradient-to-r from-a1 to-a2 bg-clip-text text-transparent">trabajaron</span> los estudiantes?
    </h2>
    <p class="text-[clamp(14px,1.4vw,16px)] text-t2 font-light leading-relaxed max-w-[580px] mb-10">
      Cada videojuego siguió un proceso real de ingeniería de software — desde el análisis de requerimientos hasta el uso por niños de primer grado en la Expo Carrera.
    </p>
    <div class="flex flex-col max-w-[760px] relative before:content-[''] before:absolute before:left-[23px] before:top-10 before:bottom-10 before:w-0.5 before:bg-gradient-to-b before:from-a1/10 before:via-a1/40 before:via-a2/40 before:via-a3/30 before:to-a1/10">
      {timeline.map((item) => (
        <div class="grid grid-cols-[48px_1fr] gap-6 py-6 relative">
          <div class="w-12 h-12 rounded-full bg-bg3 border-2 border-white/10 flex items-center justify-center text-[22px] shrink-0 relative z-1">
            <span class="block leading-none">{item.emoji}</span>
          </div>
          <div class="bg-bg3 border border-white/5 rounded-xl p-6 transition-colors">
            <div class="font-mono text-[9px] tracking-wider uppercase text-a1 mb-1.5">{item.step}</div>
            <h3 class="text-[17px] font-semibold text-t1 mb-2">{item.title}</h3>
            <p class="text-[13px] text-t2 leading-relaxed font-light">{item.text}</p>
            <div class="flex flex-wrap gap-1.5 mt-3">
              {item.chips.map((chip) => (
                <Tag key={chip} variant="a1">{chip}</Tag>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="flex justify-center mt-12">
      <Button href="/juegos">Ver los videojuegos →</Button>
    </div>
  </Section>
</BaseLayout>
