---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader";
import Section from "../components/ui/Section.astro";
import Button from "../components/ui/Button.astro";
import GameCard from "../components/GameCard";
import Reveal from "../components/Reveal.astro";
import { games } from "../data/games";
---

<BaseLayout title="Videojuegos">
  <Section>
    <SectionHeader
      as="h1"
      eyebrow="Estación 05 · Producción estudiantil"
      title="Los"
      highlight="Videojuegos"
      subtitle="Ocho videojuegos educativos creados desde cero por estudiantes de la Tecnicatura. Cada uno con mecánicas originales, diseño propio e impacto pedagógico medible."
    />

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
      {
        games.map((game) => (
          <Reveal>
            <div id={game.slug} key={game.slug}>
              <GameCard game={game} />
            </div>
          </Reveal>
        ))
      }
    </div>

    <div class="flex justify-center mt-12">
      <Button href="/equipo">Conocé a los desarrolladores →</Button>
    </div>
  </Section>
</BaseLayout>

<style>
  @keyframes glow-pulse {
    0%,
    100% {
      box-shadow:
        0 0 0 2px var(--color-a1),
        0 0 30px rgba(79, 127, 255, 0.25),
        0 0 80px rgba(79, 127, 255, 0.12);
    }
    50% {
      box-shadow:
        0 0 0 2px var(--color-a1),
        0 0 50px rgba(79, 127, 255, 0.45),
        0 0 120px rgba(79, 127, 255, 0.2);
    }
  }

  [id] {
    scroll-margin-top: 30vh;
    border-radius: 20px;
  }
  [id]:target {
    animation: glow-pulse 2s ease-in-out infinite;
  }
</style>
