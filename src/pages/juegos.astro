---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader";
import Section from "../components/ui/Section.astro";
import Button from "../components/ui/Button.astro";
import GameCard from "../components/GameCard";
import { games } from "../data/games";
---

<BaseLayout title="Videojuegos — 8 juegos educativos">
  <Section>
    <SectionHeader eyebrow="Producción estudiantil" title="Los" highlight="Videojuegos" subtitle="Ocho videojuegos educativos creados desde cero por estudiantes de la Tecnicatura. Cada uno con mecánicas originales, diseño propio e impacto pedagógico medible." />

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
      {games.map((game) => (
        <GameCard game={game} key={game.slug} />
      ))}
    </div>

    <div class="flex justify-center mt-12">
      <Button href="/equipo">Conocé a los desarrolladores →</Button>
    </div>
  </Section>
</BaseLayout>
