---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader";
import Section from "../components/ui/Section.astro";
import Button from "../components/ui/Button.astro";
import SectionEyebrow from "../components/ui/SectionEyebrow.astro";
import BannerCard from "../components/ui/BannerCard.astro";
import StatNumber from "../components/ui/StatNumber.astro";
import Tag from "../components/ui/Tag.astro";
import CurriculumYear from "../components/ui/CurriculumYear.astro";
import CareerCard from "../components/ui/CareerCard.astro";
import { curriculum, careerCards, carreraStats, institucionStats } from "../data/content";
---

<BaseLayout title="La Carrera — Desarrollo de Software">
  <Section>
    <SectionHeader eyebrow="Tecnicatura Universitaria · UPC" title="La carrera de" highlight="Desarrollo de Software" subtitle="Formación universitaria presencial en La Carlota. Título oficial de la UPC, práctica profesional desde el primer año y salida laboral inmediata en el mercado tecnológico." />

    <BannerCard>
      <div class="grid lg:grid-cols-[1fr_auto] gap-10 items-center">
        <div>
          <div class="font-mono text-[9px] tracking-wider uppercase text-a1/70 mb-2.5">Institución educativa · La Carlota, Córdoba</div>
          <h3 class="text-[clamp(22px,3vw,34px)] font-extrabold text-t1 tracking-tight leading-[1.1] mb-2">
            Escuela Educativa Superior <span class="bg-gradient-to-r from-a1 to-a2 bg-clip-text text-transparent">"El Nacional"</span>
          </h3>
          <div class="font-mono text-[11px] tracking-wider text-t3 flex items-center gap-2 mb-3.5">
            📍 La Carlota · Provincia de Córdoba · Argentina
          </div>
          <p class="text-[14px] text-t2 leading-relaxed font-light max-w-[540px]">
            Institución de nivel secundario y superior comprometida con la formación integral de sus estudiantes. Ofrece una propuesta educativa moderna que combina el rigor académico con la práctica profesional, preparando a los jóvenes para los desafíos del mercado laboral del siglo XXI.
          </p>
          <div class="flex flex-wrap gap-2 mt-3.5">
            <Tag variant="pill-green">✓ Nivel secundario</Tag>
            <Tag variant="pill-green">✓ Nivel superior</Tag>
            <Tag variant="pill-a1">Convenio UPC</Tag>
          </div>
        </div>
        <div class="flex flex-col gap-2.5 shrink-0">
          {institucionStats.map((s) => (
            <StatNumber number={s.number} suffix={s.suffix} label={s.label} />
          ))}
        </div>
      </div>
    </BannerCard>

    <div class="grid md:grid-cols-2 gap-4 mb-6">
      <div class="bg-bg2 border border-white/5 rounded-xl p-6 flex flex-col gap-3.5 transition-all hover:border-a1/25 hover:-translate-y-0.5">
        <div class="flex items-center gap-3">
          <span class="text-[28px]">🏫</span>
          <div>
            <h3 class="text-[15px] font-bold text-t1">Nivel Secundario</h3>
            <div class="font-mono text-[9px] tracking-wider uppercase text-a1 mt-0.5">Educación obligatoria</div>
          </div>
        </div>
        <p class="text-[13px] text-t2 leading-relaxed">Formación general con orientación en ciencias y humanidades. Preparación para el ingreso al nivel superior y para el mundo laboral. Bachillerato completo con materias optativas que acercan al alumno al pensamiento científico y tecnológico.</p>
      </div>
      <div class="bg-bg2 border border-white/5 rounded-xl p-6 flex flex-col gap-3.5 transition-all hover:border-a1/25 hover:-translate-y-0.5">
        <div class="flex items-center gap-3">
          <span class="text-[28px]">🎓</span>
          <div>
            <h3 class="text-[15px] font-bold text-t1">Nivel Superior</h3>
            <div class="font-mono text-[9px] tracking-wider uppercase text-a1 mt-0.5">Tecnicaturas universitarias · UPC</div>
          </div>
        </div>
        <p class="text-[13px] text-t2 leading-relaxed">Tecnicaturas universitarias en convenio con la <strong class="text-t1 font-medium">Universidad Provincial de Córdoba (UPC)</strong>. Títulos oficiales con validez nacional, formación práctica desde el primer año y salida laboral inmediata en áreas de alta demanda.</p>
        <div class="flex flex-col gap-1.5">
          <div class="flex items-center gap-2.5 py-2 px-3 bg-bg3 rounded-md border border-white/5 text-[12px] transition-colors hover:border-a1/20">
            <span class="w-[5px] h-[5px] rounded-full bg-a3 shrink-0 shadow-[0_0_5px_#00c8ff]"></span>
            <span class="font-medium text-t1 flex-1">Programación Full Stack</span>
            <span class="font-mono text-[9px] text-t3">3 años · Este proyecto</span>
          </div>
          <div class="flex items-center gap-2.5 py-2 px-3 bg-bg3 rounded-md border border-white/5 text-[12px] transition-colors hover:border-a1/20">
            <span class="w-[5px] h-[5px] rounded-full bg-green shrink-0 shadow-[0_0_5px_#4fbb7c]"></span>
            <span class="font-medium text-t1 flex-1">Administración de Empresas</span>
            <span class="font-mono text-[9px] text-t3">Nivel superior</span>
          </div>
          <div class="flex items-center gap-2.5 py-2 px-3 bg-bg3 rounded-md border border-white/5 text-[12px] transition-colors hover:border-a1/20">
            <span class="w-[5px] h-[5px] rounded-full bg-orange shrink-0 shadow-[0_0_5px_#ff9f43]"></span>
            <span class="font-medium text-t1 flex-1">Otras tecnicaturas</span>
            <span class="font-mono text-[9px] text-t3">Formación superior</span>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-bg2 border border-a1/25 rounded-xl p-[18px_24px] flex items-center gap-4 mb-12">
      <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-a1 to-a2 flex items-center justify-center font-extrabold text-[12px] text-white shrink-0">UPC</div>
      <div>
        <div class="text-[12px] font-semibold text-t1 mb-0.5">Universidad Provincial de Córdoba — UPC</div>
        <p class="text-[11px] text-t3 leading-relaxed">El Nacional forma parte de la red de instituciones asociadas a la UPC, garantizando títulos universitarios oficiales de nivel superior con reconocimiento nacional.</p>
      </div>
    </div>

    <BannerCard>
      <div class="grid lg:grid-cols-[1fr_auto] gap-8 items-center">
        <div>
          <div class="font-mono text-[9px] tracking-wider uppercase text-a1/75 mb-2">Título oficial · Universidad Provincial de Córdoba</div>
          <h3 class="text-[clamp(16px,2.2vw,22px)] font-bold text-t1 tracking-tight leading-tight mb-3">Técnico Universitario en Programación Full Stack</h3>
          <div class="flex flex-wrap gap-2">
            <span class="inline-flex items-center gap-1.5 text-[12px] text-t2 px-3.5 py-1.5 bg-bg3 border border-white/5 rounded-full"><span class="text-[14px]">📍</span>La Carlota, Córdoba</span>
            <span class="inline-flex items-center gap-1.5 text-[12px] text-t2 px-3.5 py-1.5 bg-bg3 border border-white/5 rounded-full"><span class="text-[14px]">🎓</span>Título universitario</span>
            <span class="inline-flex items-center gap-1.5 text-[12px] text-t2 px-3.5 py-1.5 bg-bg3 border border-white/5 rounded-full"><span class="text-[14px]">💼</span>Práctica desde 1° año</span>
            <span class="inline-flex items-center gap-1.5 text-[12px] text-t2 px-3.5 py-1.5 bg-bg3 border border-white/5 rounded-full"><span class="text-[14px]">🏛️</span>Convenio UPC</span>
          </div>
        </div>
        <div class="flex flex-col gap-2 shrink-0 min-w-[100px] text-center">
          {carreraStats.map((s) => (
            <StatNumber number={s.number} suffix={s.suffix} suffixClass={s.suffixClass} label={s.label} />
          ))}
        </div>
      </div>
    </BannerCard>

    <SectionEyebrow text="Plan de estudios" />
    <div class="grid lg:grid-cols-3 gap-3.5 mb-10">
      {curriculum.map((year) => (
        <CurriculumYear key={year.year} year={year.year} title={year.title} subjects={year.subjects} />
      ))}
    </div>

    <SectionEyebrow text="Áreas de formación" />
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {careerCards.map((card) => (
        <CareerCard key={card.title} icon={card.icon} title={card.title} desc={card.desc} tags={card.tags} color={card.color} />
      ))}
    </div>

    <div class="flex justify-center mt-12">
      <Button href="/inscripcion">Inscribirme →</Button>
    </div>
  </Section>
</BaseLayout>
