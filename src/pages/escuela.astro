---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader";
import Section from "../components/ui/Section.astro";
import Button from "../components/ui/Button.astro";
import SectionEyebrow from "../components/ui/SectionEyebrow.astro";
import BannerCard from "../components/ui/BannerCard.astro";
import StatNumber from "../components/ui/StatNumber.astro";
import Tag from "../components/ui/Tag.astro";
import CurriculumYear from "../components/ui/CurriculumYear.astro";
import CareerCard from "../components/ui/CareerCard.astro";
import {
  curriculum,
  careerCards,
  carreraStats,
  institucionStats,
} from "../data/content";
---

<BaseLayout title="Escuela Superior — El Nacional">
  <Section>
    <SectionHeader
      as="h1"
      eyebrow="Institución educativa · La Carlota, Córdoba"
      title="Escuela Superior"
      highlight="El Nacional"
      subtitle="Institución de nivel secundario y superior comprometida con la formación integral de sus estudiantes. Ofrece tecnicaturas universitarias en convenio con la UPC, combinando el rigor académico con la práctica profesional."
    />

    <div class="h-8"></div>

    <div class="grid md:grid-cols-2 gap-4">
      <div
        class="bg-bg2 border border-white/5 rounded-xl p-6 flex flex-col gap-3.5 transition-all hover:border-a1/25 hover:-translate-y-0.5"
      >
        <div class="flex items-center gap-3">
          <span class="text-3xl">🏫</span>
          <div>
            <h3 class="text-15 font-bold text-t1">Nivel Secundario</h3>
            <div
              class="font-mono text-2xs tracking-wider uppercase text-a1 mt-0.5"
            >
              Educación obligatoria
            </div>
          </div>
        </div>
        <p class="text-15 text-t2 leading-relaxed">
          Formación general con orientación en ciencias y humanidades.
          Preparación para el ingreso al nivel superior y para el mundo laboral.
          Bachillerato completo con materias optativas que acercan al alumno al
          pensamiento científico y tecnológico.
        </p>
      </div>
      <div
        class="bg-bg2 border border-white/5 rounded-xl p-6 flex flex-col gap-3.5 transition-all hover:border-a1/25 hover:-translate-y-0.5"
      >
        <div class="flex items-center gap-3">
          <span class="text-3xl">🎓</span>
          <div>
            <h3 class="text-15 font-bold text-t1">Nivel Superior</h3>
            <div
              class="font-mono text-2xs tracking-wider uppercase text-a1 mt-0.5"
            >
              Tecnicaturas universitarias · UPC
            </div>
          </div>
        </div>
        <p class="text-15 text-t2 leading-relaxed">
          Tecnicaturas universitarias en convenio con la <strong
            class="text-t1 font-medium"
            >Universidad Provincial de Córdoba (UPC)</strong
          >. Títulos oficiales con validez nacional, formación práctica desde el
          primer año y salida laboral inmediata en áreas de alta demanda.
        </p>
        <div class="flex flex-col gap-1.5">
          <div
            class="flex items-center gap-2.5 py-2 px-3 bg-bg3 rounded-md border border-white/5 text-sm transition-colors hover:border-a1/20"
          >
            <span
              class="w-1.5 h-1.5 rounded-full bg-a3 shrink-0 shadow-[0_0_5px_var(--color-a3)]"
            ></span>
            <span class="font-medium text-t1 flex-1"
              >Programación Full Stack</span
            >
            <span class="font-mono text-2xs text-t2"
              >3 años · Este proyecto</span
            >
          </div>
          <div
            class="flex items-center gap-2.5 py-2 px-3 bg-bg3 rounded-md border border-white/5 text-sm transition-colors hover:border-a1/20"
          >
            <span
              class="w-1.5 h-1.5 rounded-full bg-green shrink-0 shadow-[0_0_5px_var(--color-green)]"
            ></span>
            <span class="font-medium text-t1 flex-1"
              >Administración de Empresas</span
            >
            <span class="font-mono text-2xs text-t2">2.5 años · Nivel superior</span>
          </div>
          <div
            class="flex items-center gap-2.5 py-2 px-3 bg-bg3 rounded-md border border-white/5 text-sm transition-colors hover:border-a1/20"
          >
            <span
              class="w-1.5 h-1.5 rounded-full bg-orange shrink-0 shadow-[0_0_5px_var(--color-orange)]"
            ></span>
            <span class="font-medium text-t1 flex-1">Otras tecnicaturas</span>
            <span class="font-mono text-2xs text-t2">Formación superior</span
            >
          </div>
        </div>
      </div>
    </div>

    <div class="h-12"></div>

    <div
      class="relative bg-linear-to-br from-bg2 to-bg3 border border-a1/30 rounded-xl p-6 flex items-center gap-5 transition-all hover:border-a1/50 hover:shadow-[0_0_24px_-4px_#4f7fff20]"
    >
      <div
        class="w-14 h-14 rounded-xl bg-linear-to-br from-a1 to-a2 flex items-center justify-center font-extrabold text-base text-white shrink-0 shadow-[0_0_16px_-2px_#4f7fff40]"
      >
        UPC
      </div>
      <div>
        <div class="text-base font-bold text-t1 mb-1">
          Universidad Provincial de Córdoba — UPC
        </div>
        <p class="text-sm text-t2 leading-relaxed">
          El Nacional forma parte de la red de instituciones asociadas a la UPC,
          garantizando títulos universitarios oficiales de nivel superior con
          reconocimiento nacional.
        </p>
      </div>
    </div>

    <div class="h-16"></div>

    <SectionEyebrow text="Tecnicatura Universitaria · UPC" />
    <div class="h-6"></div>

    <BannerCard>
      <div class="grid lg:grid-cols-[1fr_auto] gap-8 items-center">
        <div>
          <div
            class="font-mono text-2xs tracking-wider uppercase text-a1/75 mb-2"
          >
            Título oficial · Universidad Provincial de Córdoba
          </div>
          <h3
            class="text-[clamp(16px,2.2vw,22px)] font-bold text-t1 tracking-tight leading-tight mb-3"
          >
            Técnico Universitario en Programación Full Stack
          </h3>
          <div class="flex flex-wrap gap-2">
            <span
              class="inline-flex items-center gap-1.5 text-sm text-t2 px-3.5 py-1.5 bg-bg3 border border-white/5 rounded-full"
              ><span class="text-sm">📍</span>La Carlota, Córdoba</span
            >
            <span
              class="inline-flex items-center gap-1.5 text-sm text-t2 px-3.5 py-1.5 bg-bg3 border border-white/5 rounded-full"
               ><span class="text-sm">🎓</span>Título universitario</span
            >
            <span
              class="inline-flex items-center gap-1.5 text-sm text-t2 px-3.5 py-1.5 bg-bg3 border border-white/5 rounded-full"
               ><span class="text-sm">💼</span>Práctica desde 1° año</span
            >
            <span
              class="inline-flex items-center gap-1.5 text-sm text-t2 px-3.5 py-1.5 bg-bg3 border border-white/5 rounded-full"
               ><span class="text-sm">🏛️</span>Convenio UPC</span
            >
          </div>
        </div>
        <div class="flex flex-col gap-2 shrink-0 min-w-25 text-center">
          {
            carreraStats.map((s) => (
              <StatNumber
                number={s.number}
                suffix={s.suffix}
                suffixClass={s.suffixClass}
                label={s.label}
              />
            ))
          }
        </div>
      </div>
    </BannerCard>

    <div class="h-16"></div>

    <SectionEyebrow text="Plan de estudios" />
    <div class="h-6"></div>
    <div class="grid lg:grid-cols-3 gap-3.5">
      {
        curriculum.map((year) => (
          <CurriculumYear
            key={year.year}
            year={year.year}
            title={year.title}
            subjects={year.subjects}
          />
        ))
      }
    </div>

    <div class="h-16"></div>

    <SectionEyebrow text="Áreas de formación" />
    <div class="h-6"></div>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {
        careerCards.map((card) => (
          <CareerCard
            key={card.title}
            icon={card.icon}
            title={card.title}
            desc={card.desc}
            tags={card.tags}
            color={card.color}
          />
        ))
      }
    </div>

    <div class="h-12"></div>

    <div class="flex justify-center">
      <Button href="/inscripcion">Inscribirme →</Button>
    </div>
  </Section>
</BaseLayout>
