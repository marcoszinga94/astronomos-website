---
import "../styles/global.css";
import VideoOrbit from "../components/VideoOrbit";
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Videos · El Nacional</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
    <script>
      const t = localStorage.getItem("theme");
      if (t === "light") document.documentElement.classList.add("light");
    </script>
  </head>
  <body class="bg-bg text-t1 font-sans overflow-hidden">
    <VideoOrbit client:load />
  </body>
</html>
